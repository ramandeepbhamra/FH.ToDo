{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=../FHToDo.db"
  },
  "Application": {
    "Name": "FH.ToDo",
    "Version": "1.0.0",
    "SupportEmail": "support@functionhealth.com",
    "Limits": {
      "BasicUserTaskLimit": 10,
      "BasicUserTaskListLimit": 10
    }
  },
  "Jwt": {
    "Secret": "YourSuperSecretKeyThatIsAtLeast32CharactersLongForProductionUse!",
    "Issuer": "FH.ToDo.API",
    "Audience": "FH.ToDo.Client",
    "ExpirationInMinutes": 60
  },
  "Session": {
    "IdleTimeoutMinutes": 15,
    "WarningCountdownSeconds": 30
  },
  "Cors": {
    "Origins": "http://localhost:3000,http://localhost:4200,https://localhost:5001"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jira": {
    "BaseUrl": "https://yourcompany.atlassian.net",
    "Email": "you@yourcompany.com",
    "ApiToken": "YOUR_JIRA_API_TOKEN_HERE"
  },
  "Ai": {
    "Provider": "GitHub",
    "Providers": {
      "GitHub": {
        "Endpoint": "https://models.inference.ai.azure.com",
        "ApiKey": "YOUR_GITHUB_PAT_HERE",
        "Model": "gpt-4o",
        "MaxTokens": 2048
      },
      "Anthropic": {
        "Endpoint": "https://api.anthropic.com",
        "ApiKey": "YOUR_ANTHROPIC_API_KEY_HERE",
        "Model": "claude-3-5-sonnet-20241022",
        "MaxTokens": 2048
      },
      "OpenAi": {
        "Endpoint": "https://api.openai.com",
        "ApiKey": "YOUR_OPENAI_API_KEY_HERE",
        "Model": "gpt-4o",
        "MaxTokens": 2048
      }
    }
  }
}
