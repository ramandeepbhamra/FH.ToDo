###############################################################################
# FH.ToDo API - HTTP Request Collection
# 
# This file contains sample HTTP requests for testing the FH.ToDo API.
# Works with Visual Studio 2022+, VS Code (REST Client extension), and Rider.
#
# SETUP:
# 1. Ensure the backend is running: dotnet run --project FH.ToDo.Web.Host
# 2. Default URL: http://localhost:5214
# 3. Run requests sequentially - login first to get auth token
#
# TIP: Click the "Send Request" link above each request to execute it.
###############################################################################

@baseUrl = http://localhost:5214
@contentType = application/json

###############################################################################
# 1. HEALTH & CONFIG
###############################################################################

### Health Check (No Auth Required)
# @name health
GET {{baseUrl}}/health

###

### Get Public Configuration (No Auth Required)
# Returns session timeout settings for frontend
# @name config
GET {{baseUrl}}/api/config

###

###############################################################################
# 2. AUTHENTICATION
###############################################################################

### Login - Admin User
# @name loginAdmin
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "fh.admin1@yopmail.com",
  "password": "123qwe"
}

###

### Login - Basic User
# @name loginBasic
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "fh.basic1@yopmail.com",
  "password": "123qwe"
}

###

### Login - Premium User
# @name loginPremium
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "fh.premium1@yopmail.com",
  "password": "123qwe"
}

###

### Login - Dev User
# @name loginDev
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "fh.dev1@yopmail.com",
  "password": "123qwe"
}

###

### Register New User (Self-Registration)
# @name register
POST {{baseUrl}}/api/auth/register
Content-Type: {{contentType}}

{
  "email": "newuser@example.com",
  "password": "NewUser123!",
  "firstName": "New",
  "lastName": "User",
  "phoneNumber": "+1-555-0123"
}

###

### Refresh Token
# First login to get a refresh token, then use it here
# @name refresh
POST {{baseUrl}}/api/auth/refresh
Content-Type: {{contentType}}

{
  "refreshToken": "paste-refresh-token-here"
}

###

### Revoke Refresh Token (Logout)
# Requires authentication
POST {{baseUrl}}/api/auth/revoke
Authorization: Bearer {{loginAdmin.response.body.accessToken}}
Content-Type: {{contentType}}

{
  "refreshToken": "{{loginAdmin.response.body.refreshToken}}"
}

###

###############################################################################
# 3. PROFILE MANAGEMENT (Authenticated User's Own Profile)
###############################################################################

### Get Current User Profile
# Returns authenticated user's profile
GET {{baseUrl}}/api/profile
Authorization: Bearer {{loginAdmin.response.body.accessToken}}

###

### Update Current User Profile
# Update authenticated user's FirstName, LastName, PhoneNumber
PUT {{baseUrl}}/api/profile
Authorization: Bearer {{loginAdmin.response.body.accessToken}}
Content-Type: {{contentType}}

{
  "firstName": "Updated",
  "lastName": "Name",
  "phoneNumber": "+1-555-9999"
}

###

###############################################################################
# 4. USER MANAGEMENT (Admin Only)
###############################################################################

### Get All Users (with filtering)
# Query params: filter, isActive, isSystemUser, role, excludeUserId, sorting, paging
GET {{baseUrl}}/api/users?pageNumber=1&pageSize=10
Authorization: Bearer {{loginAdmin.response.body.accessToken}}

###

### Get All Users - Filtered by Name
GET {{baseUrl}}/api/users?name=John&pageNumber=1&pageSize=10
Authorization: Bearer {{loginAdmin.response.body.accessToken}}

###

### Get All Users - Filtered by Role
GET {{baseUrl}}/api/users?role=Admin&pageNumber=1&pageSize=10
Authorization: Bearer {{loginAdmin.response.body.accessToken}}

###

### Get All Users - Active Only, Exclude System Users
GET {{baseUrl}}/api/users?isActive=true&isSystemUser=false&pageNumber=1&pageSize=20
Authorization: Bearer {{loginAdmin.response.body.accessToken}}

###

### Get User by ID
GET {{baseUrl}}/api/users/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{loginAdmin.response.body.accessToken}}

###

### Create New User (Admin Only)
# @name createUser
POST {{baseUrl}}/api/users
Authorization: Bearer {{loginAdmin.response.body.accessToken}}
Content-Type: {{contentType}}

{
  "email": "admin.created@example.com",
  "password": "SecurePassword123!",
  "firstName": "Admin",
  "lastName": "Created",
  "phoneNumber": "+1-555-1234",
  "role": "Basic",
  "isActive": true
}

###

### Update User (Admin Only)
PUT {{baseUrl}}/api/users/{{createUser.response.body.id}}
Authorization: Bearer {{loginAdmin.response.body.accessToken}}
Content-Type: {{contentType}}

{
  "firstName": "Updated",
  "lastName": "User",
  "phoneNumber": "+1-555-5678",
  "role": "Premium",
  "isActive": true
}

###

### Delete User (Soft Delete - Admin Only)
DELETE {{baseUrl}}/api/users/{{createUser.response.body.id}}
Authorization: Bearer {{loginAdmin.response.body.accessToken}}

###

###############################################################################
# 5. TASK LISTS
###############################################################################

### Get All Task Lists for Current User
GET {{baseUrl}}/api/tasklists?pageNumber=1&pageSize=10
Authorization: Bearer {{loginBasic.response.body.accessToken}}

###

### Get Task List by ID
GET {{baseUrl}}/api/tasklists/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{loginBasic.response.body.accessToken}}

###

### Create Task List
# @name createTaskList
POST {{baseUrl}}/api/tasklists
Authorization: Bearer {{loginBasic.response.body.accessToken}}
Content-Type: {{contentType}}

{
  "name": "Work Tasks",
  "description": "Daily work items and project tasks",
  "color": "#FF5722"
}

###

### Update Task List
PUT {{baseUrl}}/api/tasklists/{{createTaskList.response.body.id}}
Authorization: Bearer {{loginBasic.response.body.accessToken}}
Content-Type: {{contentType}}

{
  "name": "Updated Work Tasks",
  "description": "Updated description for work tasks",
  "color": "#2196F3"
}

###

### Delete Task List (Soft Delete)
DELETE {{baseUrl}}/api/tasklists/{{createTaskList.response.body.id}}
Authorization: Bearer {{loginBasic.response.body.accessToken}}

###

###############################################################################
# 6. TODO TASKS
###############################################################################

### Get All Tasks in a Task List
GET {{baseUrl}}/api/tasklists/{{createTaskList.response.body.id}}/tasks?pageNumber=1&pageSize=10
Authorization: Bearer {{loginBasic.response.body.accessToken}}

###

### Get Task by ID
GET {{baseUrl}}/api/tasks/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{loginBasic.response.body.accessToken}}

###

### Create Todo Task
# @name createTask
POST {{baseUrl}}/api/tasks
Authorization: Bearer {{loginBasic.response.body.accessToken}}
Content-Type: {{contentType}}

{
  "taskListId": "{{createTaskList.response.body.id}}",
  "title": "Complete API documentation",
  "description": "Write comprehensive API docs for all endpoints",
  "priority": "High",
  "dueDate": "2026-04-30T23:59:59Z",
  "tags": ["documentation", "api"]
}

###

### Update Todo Task
PUT {{baseUrl}}/api/tasks/{{createTask.response.body.id}}
Authorization: Bearer {{loginBasic.response.body.accessToken}}
Content-Type: {{contentType}}

{
  "title": "Updated Task Title",
  "description": "Updated task description with more details",
  "priority": "Medium",
  "dueDate": "2026-05-15T23:59:59Z",
  "isCompleted": false,
  "tags": ["documentation", "api", "updated"]
}

###

### Mark Task as Complete
PUT {{baseUrl}}/api/tasks/{{createTask.response.body.id}}/complete
Authorization: Bearer {{loginBasic.response.body.accessToken}}

###

### Mark Task as Incomplete
PUT {{baseUrl}}/api/tasks/{{createTask.response.body.id}}/incomplete
Authorization: Bearer {{loginBasic.response.body.accessToken}}

###

### Toggle Task Favorite/Star
PUT {{baseUrl}}/api/tasks/{{createTask.response.body.id}}/toggle-favorite
Authorization: Bearer {{loginBasic.response.body.accessToken}}

###

### Delete Todo Task (Soft Delete)
DELETE {{baseUrl}}/api/tasks/{{createTask.response.body.id}}
Authorization: Bearer {{loginBasic.response.body.accessToken}}

###

###############################################################################
# 7. SUBTASKS
###############################################################################

### Get All Subtasks for a Task
GET {{baseUrl}}/api/tasks/{{createTask.response.body.id}}/subtasks
Authorization: Bearer {{loginBasic.response.body.accessToken}}

###

### Create Subtask
# @name createSubtask
POST {{baseUrl}}/api/subtasks
Authorization: Bearer {{loginBasic.response.body.accessToken}}
Content-Type: {{contentType}}

{
  "todoTaskId": "{{createTask.response.body.id}}",
  "title": "Research API best practices",
  "isCompleted": false
}

###

### Update Subtask
PUT {{baseUrl}}/api/subtasks/{{createSubtask.response.body.id}}
Authorization: Bearer {{loginBasic.response.body.accessToken}}
Content-Type: {{contentType}}

{
  "title": "Updated Subtask Title",
  "isCompleted": false
}

###

### Toggle Subtask Completion
PUT {{baseUrl}}/api/subtasks/{{createSubtask.response.body.id}}/toggle-complete
Authorization: Bearer {{loginBasic.response.body.accessToken}}

###

### Delete Subtask (Soft Delete)
DELETE {{baseUrl}}/api/subtasks/{{createSubtask.response.body.id}}
Authorization: Bearer {{loginBasic.response.body.accessToken}}

###

###############################################################################
# 8. API LOGS (Admin & Dev Only)
###############################################################################

### Get API Logs (Paginated)
GET {{baseUrl}}/api/logs?pageNumber=1&pageSize=20
Authorization: Bearer {{loginAdmin.response.body.accessToken}}

###

### Get API Logs - Filtered by Date Range
GET {{baseUrl}}/api/logs?startDate=2026-04-01&endDate=2026-04-30&pageNumber=1&pageSize=50
Authorization: Bearer {{loginAdmin.response.body.accessToken}}

###

### Get API Logs - Filtered by User
GET {{baseUrl}}/api/logs?userId={{loginBasic.response.body.user.id}}&pageNumber=1&pageSize=20
Authorization: Bearer {{loginAdmin.response.body.accessToken}}

###

###############################################################################
# NOTES
###############################################################################

# Variable Reference:
# - {{loginAdmin.response.body.accessToken}} - Admin user's JWT token
# - {{loginAdmin.response.body.refreshToken}} - Admin user's refresh token
# - {{loginAdmin.response.body.user.id}} - Admin user's ID
# - {{createTaskList.response.body.id}} - Created task list ID
# - {{createTask.response.body.id}} - Created task ID
# - {{createSubtask.response.body.id}} - Created subtask ID

# Test Users (All seeded automatically):
# - fh.admin1@yopmail.com   (Role: Admin, Password: 123qwe)
# - fh.basic1@yopmail.com   (Role: Basic, Password: 123qwe)
# - fh.premium1@yopmail.com (Role: Premium, Password: 123qwe)
# - fh.dev1@yopmail.com     (Role: Dev, Password: 123qwe)
#
# Additional users: fh.admin2-10, fh.basic2-10, etc. (40 total)

# How to Use:
# 1. Start backend: dotnet run --project FH.ToDo.Web.Host
# 2. Execute "Login - Admin User" request first
# 3. VS 2022 will automatically capture the accessToken
# 4. Subsequent requests use {{loginAdmin.response.body.accessToken}}
# 5. Click "Send Request" above any ### section

# Endpoints Requiring Authentication:
# - Profile management (GET/PUT /api/profile)
# - User management (All /api/users endpoints - Admin only)
# - Task lists (All /api/tasklists endpoints)
# - Tasks (All /api/tasks endpoints)
# - Subtasks (All /api/subtasks endpoints)
# - API logs (GET /api/logs - Admin/Dev only)

# Public Endpoints (No Auth):
# - GET /health
# - GET /api/config
# - POST /api/auth/login
# - POST /api/auth/register
# - POST /api/auth/refresh
