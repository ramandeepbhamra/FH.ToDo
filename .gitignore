## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Files built by Visual Studio
*.dll
*.exe
*.pdb
*.cache
*.obj
*.log

# NuGet Packages
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets

# SQL Server files
*.mdf
*.ldf

# SQLite database files (generated at runtime on startup)
*.db
*.db-shm
*.db-wal

# Entity Framework Core
appsettings.*.local.json

# Visual Studio backup files
*.Backup.tmp
*.bak

# Node.js / npm (Frontend & Playwright)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm
.yarn

# Angular / Frontend
dist/
tmp/
.angular/
.cache/

# Playwright test results
test-results/
playwright-report/
playwright/.cache/
.playwright/
screenshots/
videos/
downloads/

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
